                            ></textarea>
                            <div class="absolute bottom-2 right-3 text-xs text-gray-500">
                                <span x-text="(comment?.length || 0)"></span>/255
                            </div>
                        </div>
                        @error('formData.comment')
                            <p class="mt-2 text-sm text-red-600">{{ $message }}</p>
                        @enderror
                    </div>

                    <button
                        type="submit"
                        class="py-4 w-full font-semibold text-white bg-blue-600 rounded-full shadow-md disabled:opacity-60"
                        wire:loading.attr="disabled"
                    >
                        <span wire:loading.remove>Kirim</span>
                        <span wire:loading>Memproses…</span>
                    </button>
                </form>
            @endif
        </div>

        <div class="flex-1"></div>
    </div>
</x-filament::page>
