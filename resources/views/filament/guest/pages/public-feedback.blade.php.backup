                <form
                    wire:submit.prevent="save"
                    x-data="{
                        rate: @entangle('formData.rate').defer,
                        comment: @entangle('formData.comment').defer,
                        hovering: 0
                    }"
                    class="mt-8 space-y-8"
                >
                    <div class="text-center">
                        <p class="font-semibold text-blue-700">Berikan Penilaian</p>

                        {{-- <div
                            class="flex gap-3 justify-center items-center mt-3 select-none"
                            x-data="{
                                value: @entangle('data.rate').defer || 0,
                                hover: 0,
                                isH(i){ return this.hover >= i },
                                isA(i){ return this.value >= i },
                                set(n){ this.value = n }
                            }"
                            role="radiogroup"
                            aria-label="Berikan penilaian"
                        > --}}
                        <div
                            class="flex gap-3 justify-center items-center mt-3 select-none"
                            x-data="{
                                value: @entangle('formData.rate').defer || 0,
                                hover: 0,
                                isH(i){ return this.hover >= i },
                                isA(i){ return this.value >= i },
                                set(n){ this.value = n }
                            }"
                            role="radiogroup"
                            aria-label="Berikan penilaian"
                        >
                            <template x-for="i in 5" :key="i">
                                <button
                                    type="button"
                                    class="relative w-11 h-11 rounded-full outline-none focus:ring-2 focus:ring-blue-600/40"
                                    role="radio"
                                    :aria-checked="value === i"
                                    @click="set(i)"
                                    @mouseenter="hover = i" @mouseleave="hover = 0"
                                    @keydown.arrow-right.prevent="set(Math.min(5, (value||0)+1))"
                                    @keydown.arrow-left.prevent="set(Math.max(1, (value||0)-1))"
                                >
                                    {{-- fill layer --}}
                                    <svg viewBox="0 0 24 24"
                                         class="absolute inset-0 m-auto w-11 h-11 transition-transform duration-150"
                                         :class="isH(i)
                                            ? 'text-yellow-400 scale-110 drop-shadow-[0_2px_8px_rgba(234,179,8,0.55)]'
                                            : (isA(i)
                                                ? 'text-yellow-500 scale-105 drop-shadow-[0_2px_8px_rgba(234,179,8,0.45)]'
                                                : 'text-transparent scale-100')">
                                        <polygon fill="currentColor"
                                                 points="12,2.4 14.65,7.83 20.6,8.69 16.3,12.86 17.32,18.74 12,15.96 6.68,18.74 7.7,12.86 3.4,8.69 9.35,7.83 "></polygon>
                                    </svg>
                                    {{-- outline layer --}}
                                    <svg viewBox="0 0 24 24" class="absolute inset-0 m-auto w-11 h-11">
                                        <polygon
                                            :class="(isH(i) || isA(i)) ? 'text-yellow-500' : 'text-gray-300'"
                                            fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"
                                            points="12,2.8 14.34,7.55 19.6,8.3 15.8,11.98 16.66,17.2 12,14.84 7.34,17.2 8.2,11.98 4.4,8.3 9.66,7.55 "></polygon>
                                    </svg>
                                    <span class="sr-only" x-text="i + ' bintang'"></span>
                                </button>
                            </template>
                        </div>

                        @error('formData.rate')
